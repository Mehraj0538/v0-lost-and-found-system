# MongoDB Connection String
# Get your MongoDB URI from MongoDB Atlas or local MongoDB instance
# Format: mongodb+srv://username:password@cluster.mongodb.net/database
# Or for local: mongodb://localhost:27017/database
MONGODB_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/lost-and-found

# JWT Secret for Token Signing
# Change this to a strong random string in production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Node Environment
NODE_ENV=development
